# === Required ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
RUNNER_API_KEY=your-runner-api-key
FOUNDRY_API_KEY=your-azure-ai-foundry-api-key
GH_TOKEN=your-github-pat

# === Optional (with defaults) ===
FOUNDRY_BASE_URL=https://your-endpoint.cognitiveservices.azure.com/openai/v1
MODEL=gpt-5.2
APPS_ORG=aw-apps
LOG_REPO=yazelin/byok-tg-main
NOTIFY_REPO=yazelin/byok-tg-main
NOTIFY_CHAT_ID=your-telegram-chat-id

# === Callback (Worker ↔ Runner) ===
CALLBACK_URL=https://your-worker.workers.dev
CALLBACK_TOKEN=your-callback-secret

# === Runner workflow only (set as GitHub secrets) ===
# CF_ACCOUNT_ID=your-cloudflare-account-id
# CF_API_TOKEN=your-cloudflare-api-token
# KV_NAMESPACE_ID=your-kv-namespace-id
